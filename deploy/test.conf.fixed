# test.conf.fixed — 三节点固定拓扑模板（非脚本，纯配置）
# cluster_up.sh 会复制为本目录上一级的 test.conf，供 raftCoreRun -u 与客户端使用。
# 端口：127.0.0.1:19001 / 19002 / 19003
# =============================================================================
node0ip=127.0.0.1
node0port=19001
node1ip=127.0.0.1
node1port=19002
node2ip=127.0.0.1
node2port=19003
